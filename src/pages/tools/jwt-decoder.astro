---
import Base from '../../layouts/Base.astro';
---
<Base title="JWT Decoder" description="Free online JWT decoder. Decode and inspect JSON Web Tokens. View header, payload and expiry. Runs entirely in your browser — token never leaves your device.">

  <nav style="font-size:0.8rem;color:var(--color-muted);margin-bottom:1.5rem;">
    <a href="/" style="color:var(--color-muted);text-decoration:none;" onmouseover="this.style.color='var(--color-heading)'" onmouseout="this.style.color='var(--color-muted)'">All Tools</a>
    <span style="margin:0 0.5rem;">›</span>
    <span style="color:var(--color-body);">JWT Decoder</span>
  </nav>

  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
      <span style="font-size:1.5rem;">🪙</span>
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--color-heading);margin:0;">JWT Decoder</h1>
    </div>
    <p style="color:var(--color-muted);font-size:0.9rem;margin:0;">Decode and inspect JSON Web Tokens. Your token never leaves your browser.</p>
  </div>

  <!-- Input -->
  <div style="margin-bottom:1rem;">
    <label style="font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-muted);display:block;margin-bottom:0.4rem;">JWT Token</label>
    <textarea id="jwt-input" rows="4" placeholder="Paste your JWT token here: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." spellcheck="false"
      style="width:100%;font-family:'JetBrains Mono',monospace;font-size:0.82rem;line-height:1.6;background:var(--color-surface);color:var(--color-body);border:1px solid var(--color-border);border-radius:12px;padding:1rem;resize:vertical;outline:none;transition:border-color 0.15s;"
      onfocus="this.style.borderColor='var(--color-accent)'" onblur="this.style.borderColor='var(--color-border)'" oninput="decodeJWT()"></textarea>
  </div>

  <div id="status" style="font-size:0.85rem;font-family:'JetBrains Mono',monospace;min-height:1.2rem;margin-bottom:1rem;"></div>

  <!-- Results -->
  <div id="results" style="display:none;flex-direction:column;gap:1rem;">
    <!-- Parts visual -->
    <div id="parts-visual" style="font-family:'JetBrains Mono',monospace;font-size:0.78rem;line-height:1.8;background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1rem;word-break:break-all;"></div>

    <!-- Header -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.25rem;">
      <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#F59E0B;margin-bottom:0.5rem;">Header</div>
      <pre id="jwt-header" style="font-family:'JetBrains Mono',monospace;font-size:0.82rem;color:var(--color-body);margin:0;white-space:pre-wrap;"></pre>
    </div>

    <!-- Payload -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.25rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
        <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#22C55E;">Payload</span>
        <span id="expiry-badge" style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;"></span>
      </div>
      <pre id="jwt-payload" style="font-family:'JetBrains Mono',monospace;font-size:0.82rem;color:var(--color-body);margin:0;white-space:pre-wrap;"></pre>
    </div>

    <!-- Signature -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.25rem;">
      <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#6366F1;margin-bottom:0.5rem;">Signature (not verified)</div>
      <div id="jwt-sig" style="font-family:'JetBrains Mono',monospace;font-size:0.78rem;color:var(--color-muted);word-break:break-all;"></div>
    </div>
  </div>
</Base>

<script>
  function b64Decode(str: string): string {
    str = str.replace(/-/g, '+').replace(/_/g, '/');
    while (str.length % 4) str += '=';
    return decodeURIComponent(atob(str).split('').map(c =>
      '%' + c.charCodeAt(0).toString(16).padStart(2,'0')
    ).join(''));
  }

  function decodeJWT() {
    const token = (document.getElementById('jwt-input') as HTMLTextAreaElement).value.trim();
    const status = document.getElementById('status')!;
    const results = document.getElementById('results')!;

    if (!token) { status.textContent = ''; results.style.display = 'none'; return; }

    const parts = token.split('.');
    if (parts.length !== 3) {
      status.textContent = '✗ Invalid JWT — must have 3 parts separated by dots';
      status.style.color = 'var(--color-danger)';
      results.style.display = 'none';
      return;
    }

    try {
      const header  = JSON.parse(b64Decode(parts[0]));
      const payload = JSON.parse(b64Decode(parts[1]));

      document.getElementById('jwt-header')!.textContent  = JSON.stringify(header, null, 2);
      document.getElementById('jwt-payload')!.textContent = JSON.stringify(payload, null, 2);
      document.getElementById('jwt-sig')!.textContent     = parts[2];

      // Visual parts
      const pv = document.getElementById('parts-visual')!;
      pv.innerHTML = `<span style="color:#F59E0B;">${parts[0]}</span>.<span style="color:#22C55E;">${parts[1]}</span>.<span style="color:#6366F1;">${parts[2]}</span>`;

      // Expiry
      const badge = document.getElementById('expiry-badge')!;
      if (payload.exp) {
        const exp = new Date(payload.exp * 1000);
        const expired = exp < new Date();
        badge.textContent = expired ? `✗ Expired ${exp.toLocaleString()}` : `✓ Expires ${exp.toLocaleString()}`;
        badge.style.color = expired ? 'var(--color-danger)' : 'var(--color-success)';
      } else {
        badge.textContent = 'No expiry';
        badge.style.color = 'var(--color-muted)';
      }

      status.textContent = '✓ Valid JWT structure';
      status.style.color = 'var(--color-success)';
      results.style.display = 'flex';
    } catch (e: any) {
      status.textContent = `✗ ${e.message}`;
      status.style.color = 'var(--color-danger)';
      results.style.display = 'none';
    }
  }

  (window as any).decodeJWT = decodeJWT;
</script>
