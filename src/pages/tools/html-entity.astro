---
import Base from '../../layouts/Base.astro';
---
<Base title="HTML Entity Encoder / Decoder" description="Free online HTML entity encoder and decoder. Convert special characters to HTML entities and back. Runs entirely in your browser.">

  <nav style="font-size:0.8rem;color:var(--color-muted);margin-bottom:1.5rem;">
    <a href="/" style="color:var(--color-muted);text-decoration:none;" onmouseover="this.style.color='var(--color-heading)'" onmouseout="this.style.color='var(--color-muted)'">All Tools</a>
    <span style="margin:0 0.5rem;">›</span>
    <span style="color:var(--color-body);">HTML Entity Encoder / Decoder</span>
  </nav>

  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
      <span style="font-size:1.5rem;">🏷️</span>
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--color-heading);margin:0;">HTML Entity Encoder / Decoder</h1>
    </div>
    <p style="color:var(--color-muted);font-size:0.9rem;margin:0;">Encode special characters like &lt; &gt; &amp; &quot; into HTML entities, or decode them back to plain text.</p>
  </div>

  <!-- Mode tabs -->
  <div style="display:flex;gap:0.5rem;margin-bottom:1rem;">
    <button id="tab-encode" onclick="setMode('encode')" style="padding:0.4rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;background:var(--color-accent);color:#fff;border:none;">Encode</button>
    <button id="tab-decode" onclick="setMode('decode')" style="padding:0.4rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;cursor:pointer;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);">Decode</button>
  </div>

  <!-- Panels -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
    <div style="display:flex;flex-direction:column;gap:0.4rem;">
      <span id="label-in" style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-muted);">Input (plain HTML)</span>
      <textarea id="input" placeholder="Paste HTML or text here..." spellcheck="false"
        style="flex:1;font-family:'JetBrains Mono',monospace;font-size:0.82rem;line-height:1.6;background:var(--color-surface);color:var(--color-body);border:1px solid var(--color-border);border-radius:12px;padding:1rem;resize:none;outline:none;min-height:320px;transition:border-color 0.15s;"
        onfocus="this.style.borderColor='var(--color-accent)'" onblur="this.style.borderColor='var(--color-border)'" oninput="convert()"></textarea>
    </div>
    <div style="display:flex;flex-direction:column;gap:0.4rem;">
      <span id="label-out" style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-muted);">Output (encoded)</span>
      <pre id="output" style="flex:1;font-family:'JetBrains Mono',monospace;font-size:0.82rem;line-height:1.6;background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1rem;margin:0;overflow:auto;white-space:pre-wrap;word-break:break-all;min-height:320px;color:#a8ffb0;"></pre>
    </div>
  </div>

  <div style="display:flex;gap:0.5rem;margin-top:0.75rem;">
    <button onclick="copyOutput()" style="padding:0.4rem 1rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;font-size:0.82rem;font-weight:500;cursor:pointer;">📋 Copy</button>
    <button onclick="clearAll()" style="padding:0.4rem 1rem;background:var(--color-surface2);color:var(--color-muted);border:1px solid var(--color-border);border-radius:8px;font-size:0.82rem;font-weight:500;cursor:pointer;">Clear</button>
    <span id="status" style="font-size:0.82rem;color:var(--color-success);align-self:center;font-family:'JetBrains Mono',monospace;"></span>
  </div>
</Base>

<script>
  let mode = 'encode';

  function setMode(m: string) {
    mode = m;
    const encBtn = document.getElementById('tab-encode')!;
    const decBtn = document.getElementById('tab-decode')!;
    if (m === 'encode') {
      encBtn.style.cssText = 'padding:0.4rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;background:var(--color-accent);color:#fff;border:none;';
      decBtn.style.cssText = 'padding:0.4rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;cursor:pointer;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);';
      document.getElementById('label-in')!.textContent = 'Input (plain HTML)';
      document.getElementById('label-out')!.textContent = 'Output (encoded)';
    } else {
      decBtn.style.cssText = 'padding:0.4rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;background:var(--color-accent);color:#fff;border:none;';
      encBtn.style.cssText = 'padding:0.4rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;cursor:pointer;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);';
      document.getElementById('label-in')!.textContent = 'Input (entities)';
      document.getElementById('label-out')!.textContent = 'Output (decoded)';
    }
    convert();
  }

  function encodeEntities(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function decodeEntities(str: string): string {
    return str
      .replace(/&#39;/g, "'")
      .replace(/&quot;/g, '"')
      .replace(/&gt;/g, '>')
      .replace(/&lt;/g, '<')
      .replace(/&amp;/g, '&');
  }

  function convert() {
    const val = (document.getElementById('input') as HTMLTextAreaElement).value;
    const out = document.getElementById('output')!;
    const status = document.getElementById('status')!;
    if (!val) { out.textContent = ''; status.textContent = ''; return; }
    try {
      out.textContent = mode === 'encode' ? encodeEntities(val) : decodeEntities(val);
      status.textContent = '';
    } catch (e: any) {
      out.textContent = '';
      status.textContent = `✗ ${e.message}`;
      status.style.color = 'var(--color-danger)';
    }
  }

  function copyOutput() {
    const text = document.getElementById('output')!.textContent;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      const s = document.getElementById('status')!;
      s.textContent = '✓ Copied!';
      s.style.color = 'var(--color-success)';
    });
  }

  function clearAll() {
    (document.getElementById('input') as HTMLTextAreaElement).value = '';
    document.getElementById('output')!.textContent = '';
    document.getElementById('status')!.textContent = '';
  }

  (window as any).setMode = setMode;
  (window as any).convert = convert;
  (window as any).copyOutput = copyOutput;
  (window as any).clearAll = clearAll;
</script>
