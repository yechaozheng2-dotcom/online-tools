---
import Base from '../../layouts/Base.astro';
---
<Base title="UUID Generator" description="Free online UUID v4 generator. Generate single or bulk UUIDs instantly using the browser's crypto API. No data sent to server.">

  <nav style="font-size:0.8rem;color:var(--color-muted);margin-bottom:1.5rem;">
    <a href="/" style="color:var(--color-muted);text-decoration:none;" onmouseover="this.style.color='var(--color-heading)'" onmouseout="this.style.color='var(--color-muted)'">All Tools</a>
    <span style="margin:0 0.5rem;">›</span>
    <span style="color:var(--color-body);">UUID Generator</span>
  </nav>

  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
      <span style="font-size:1.5rem;">⬡</span>
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--color-heading);margin:0;">UUID Generator</h1>
    </div>
    <p style="color:var(--color-muted);font-size:0.9rem;margin:0;">Generate UUID v4 identifiers using your browser's crypto API. Cryptographically random.</p>
  </div>

  <!-- Single UUID -->
  <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:14px;padding:1.5rem;margin-bottom:1rem;">
    <div style="display:flex;align-items:center;gap:1rem;">
      <span id="single-uuid" style="font-family:'JetBrains Mono',monospace;font-size:1.1rem;font-weight:500;color:var(--color-heading);flex:1;letter-spacing:0.03em;"></span>
      <button onclick="copySingle()" style="padding:0.4rem 0.75rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;font-size:0.8rem;cursor:pointer;" onmouseover="this.style.borderColor='var(--color-accent)'" onmouseout="this.style.borderColor='var(--color-border)'">📋 Copy</button>
      <button onclick="generateSingle()" style="padding:0.4rem 0.75rem;background:var(--color-accent);color:#fff;border:none;border-radius:8px;font-size:0.8rem;font-weight:600;cursor:pointer;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">🔄 New</button>
    </div>
  </div>

  <!-- Bulk -->
  <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:14px;padding:1.5rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
      <span style="font-size:0.9rem;font-weight:600;color:var(--color-body);">Generate</span>
      <input id="bulk-count" type="number" min="1" max="100" value="10"
        style="width:70px;font-family:'JetBrains Mono',monospace;font-size:0.9rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;padding:0.35rem 0.5rem;outline:none;text-align:center;" />
      <span style="font-size:0.9rem;color:var(--color-body);">UUIDs</span>
      <button onclick="generateBulk()" style="padding:0.4rem 1rem;background:var(--color-accent);color:#fff;border:none;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Generate</button>
      <button onclick="copyBulk()" style="padding:0.4rem 1rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;font-size:0.85rem;font-weight:500;cursor:pointer;" onmouseover="this.style.borderColor='var(--color-accent)'" onmouseout="this.style.borderColor='var(--color-border)'">📋 Copy all</button>
    </div>
    <pre id="bulk-output" style="font-family:'JetBrains Mono',monospace;font-size:0.82rem;line-height:1.8;background:var(--color-surface2);border-radius:10px;padding:1rem;margin:0;max-height:360px;overflow:auto;color:#a8ffb0;white-space:pre;"></pre>
  </div>
  <div id="status" style="margin-top:0.5rem;font-size:0.8rem;font-family:'JetBrains Mono',monospace;color:var(--color-success);min-height:1rem;"></div>
</Base>

<script>
  function uuid(): string {
    return crypto.randomUUID();
  }

  function generateSingle() {
    document.getElementById('single-uuid')!.textContent = uuid();
  }

  function copySingle() {
    const val = document.getElementById('single-uuid')!.textContent || '';
    navigator.clipboard.writeText(val).then(() => {
      document.getElementById('status')!.textContent = '✓ Copied!';
      setTimeout(() => document.getElementById('status')!.textContent = '', 2000);
    });
  }

  function generateBulk() {
    const n = Math.min(100, Math.max(1, parseInt((document.getElementById('bulk-count') as HTMLInputElement).value) || 10));
    const uuids = Array.from({length: n}, uuid);
    document.getElementById('bulk-output')!.textContent = uuids.join('\n');
    document.getElementById('status')!.textContent = `✓ Generated ${n} UUIDs`;
  }

  function copyBulk() {
    const text = document.getElementById('bulk-output')!.textContent || '';
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      document.getElementById('status')!.textContent = '✓ Copied all!';
      setTimeout(() => document.getElementById('status')!.textContent = '', 2000);
    });
  }

  (window as any).generateSingle = generateSingle;
  (window as any).copySingle = copySingle;
  (window as any).generateBulk = generateBulk;
  (window as any).copyBulk = copyBulk;

  generateSingle();
  generateBulk();
</script>
