---
import Base from '../../layouts/Base.astro';
---
<Base title="Color Picker & Converter" description="Free online color picker and converter. Pick colors and convert between HEX, RGB, HSL and CSS formats instantly in your browser.">

  <nav style="font-size:0.8rem;color:var(--color-muted);margin-bottom:1.5rem;">
    <a href="/" style="color:var(--color-muted);text-decoration:none;" onmouseover="this.style.color='var(--color-heading)'" onmouseout="this.style.color='var(--color-muted)'">All Tools</a>
    <span style="margin:0 0.5rem;">›</span>
    <span style="color:var(--color-body);">Color Picker</span>
  </nav>

  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
      <span style="font-size:1.5rem;">🎨</span>
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--color-heading);margin:0;">Color Picker & Converter</h1>
    </div>
    <p style="color:var(--color-muted);font-size:0.9rem;margin:0;">Pick any color and instantly get HEX, RGB, HSL and CSS values.</p>
  </div>

  <div style="display:grid;grid-template-columns:280px 1fr;gap:1.5rem;align-items:start;">
    <!-- Left: picker -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:14px;padding:1.5rem;display:flex;flex-direction:column;align-items:center;gap:1rem;">
      <input type="color" id="picker" value="#6366F1"
        style="width:160px;height:160px;border:none;border-radius:12px;cursor:pointer;background:none;padding:0;"
        oninput="onPick(this.value)" />
      <!-- Preview swatch -->
      <div id="swatch" style="width:100%;height:48px;border-radius:10px;border:1px solid var(--color-border);transition:background 0.1s;background:#6366F1;"></div>
      <input id="hex-input" type="text" value="#6366F1" maxlength="7" placeholder="#RRGGBB"
        style="width:100%;font-family:'JetBrains Mono',monospace;font-size:1rem;text-align:center;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;padding:0.5rem;outline:none;transition:border-color 0.15s;"
        onfocus="this.style.borderColor='var(--color-accent)'" onblur="this.style.borderColor='var(--color-border)'"
        oninput="onHexInput(this.value)" />
    </div>

    <!-- Right: values -->
    <div style="display:flex;flex-direction:column;gap:0.75rem;">
      {[
        ['HEX','hex-val','#6366F1'],
        ['RGB','rgb-val','rgb(99, 102, 241)'],
        ['HSL','hsl-val','hsl(239, 84%, 67%)'],
        ['CSS var','css-val','--color: #6366F1'],
      ].map(([label, id, placeholder]) => (
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
          <div>
            <div style="font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-muted);margin-bottom:0.25rem;">{label}</div>
            <div id={id} style="font-family:'JetBrains Mono',monospace;font-size:0.95rem;color:var(--color-body);">{placeholder}</div>
          </div>
          <button onclick={`copy('${id}')`} style="flex-shrink:0;padding:0.35rem 0.7rem;background:var(--color-surface2);color:var(--color-muted);border:1px solid var(--color-border);border-radius:6px;font-size:0.78rem;cursor:pointer;" onmouseover="this.style.borderColor='var(--color-accent)'" onmouseout="this.style.borderColor='var(--color-border)'">Copy</button>
        </div>
      ))}
      <div id="copy-status" style="font-size:0.8rem;color:var(--color-success);min-height:1rem;font-family:'JetBrains Mono',monospace;"></div>
    </div>
  </div>
</Base>

<script>
  function hexToRgb(hex: string): [number,number,number] {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return [r,g,b];
  }

  function rgbToHsl(r: number,g: number,b: number): [number,number,number] {
    r/=255; g/=255; b/=255;
    const max=Math.max(r,g,b), min=Math.min(r,g,b);
    let h=0, s=0, l=(max+min)/2;
    if (max!==min) {
      const d=max-min;
      s = l>0.5 ? d/(2-max-min) : d/(max+min);
      switch(max){
        case r: h=((g-b)/d+(g<b?6:0))/6; break;
        case g: h=((b-r)/d+2)/6; break;
        case b: h=((r-g)/d+4)/6; break;
      }
    }
    return [Math.round(h*360), Math.round(s*100), Math.round(l*100)];
  }

  function updateAll(hex: string) {
    if (!/^#[0-9a-fA-F]{6}$/.test(hex)) return;
    const [r,g,b] = hexToRgb(hex);
    const [h,s,l] = rgbToHsl(r,g,b);
    document.getElementById('hex-val')!.textContent = hex.toUpperCase();
    document.getElementById('rgb-val')!.textContent = `rgb(${r}, ${g}, ${b})`;
    document.getElementById('hsl-val')!.textContent = `hsl(${h}, ${s}%, ${l}%)`;
    document.getElementById('css-val')!.textContent = `--color: ${hex.toUpperCase()};`;
    document.getElementById('swatch')!.style.background = hex;
    (document.getElementById('picker') as HTMLInputElement).value = hex;
    (document.getElementById('hex-input') as HTMLInputElement).value = hex.toUpperCase();
  }

  function onPick(hex: string) { updateAll(hex); }

  function onHexInput(val: string) {
    if (/^#?[0-9a-fA-F]{6}$/.test(val)) {
      updateAll(val.startsWith('#') ? val : '#' + val);
    }
  }

  function copy(id: string) {
    const text = document.getElementById(id)!.textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const s = document.getElementById('copy-status')!;
      s.textContent = `✓ Copied: ${text}`;
      setTimeout(() => s.textContent = '', 2000);
    });
  }

  (window as any).onPick = onPick;
  (window as any).onHexInput = onHexInput;
  (window as any).copy = copy;

  updateAll('#6366F1');
</script>
