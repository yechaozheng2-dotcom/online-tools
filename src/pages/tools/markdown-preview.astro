---
import Base from '../../layouts/Base.astro';
---
<Base title="Markdown Preview" description="Free online Markdown preview editor. Write Markdown on the left and see the rendered HTML on the right in real time. No external libraries.">

  <nav style="font-size:0.8rem;color:var(--color-muted);margin-bottom:1.5rem;">
    <a href="/" style="color:var(--color-muted);text-decoration:none;" onmouseover="this.style.color='var(--color-heading)'" onmouseout="this.style.color='var(--color-muted)'">All Tools</a>
    <span style="margin:0 0.5rem;">›</span>
    <span style="color:var(--color-body);">Markdown Preview</span>
  </nav>

  <div style="margin-bottom:1.25rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
      <span style="font-size:1.4rem;">#️⃣</span>
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--color-heading);margin:0;">Markdown Preview</h1>
    </div>
    <p style="color:var(--color-muted);font-size:0.9rem;margin:0;">Write Markdown on the left, see the live preview on the right. No external libraries.</p>
  </div>

  <div style="display:flex;justify-content:flex-end;margin-bottom:0.5rem;">
    <button onclick="copyHTML()" style="padding:0.35rem 0.9rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;font-size:0.8rem;font-weight:500;cursor:pointer;">📋 Copy HTML</button>
    <span id="status" style="margin-left:0.75rem;font-size:0.82rem;font-family:'JetBrains Mono',monospace;color:var(--color-success);align-self:center;"></span>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;min-height:540px;">
    <div style="display:flex;flex-direction:column;gap:0.4rem;">
      <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-muted);">Markdown</span>
      <textarea id="md-input" spellcheck="false"
        style="flex:1;font-family:'JetBrains Mono',monospace;font-size:0.82rem;line-height:1.65;background:var(--color-surface);color:var(--color-body);border:1px solid var(--color-border);border-radius:12px;padding:1rem;resize:none;outline:none;min-height:500px;transition:border-color 0.15s;"
        onfocus="this.style.borderColor='var(--color-accent)'" onblur="this.style.borderColor='var(--color-border)'" oninput="renderMd()"></textarea>
    </div>
    <div style="display:flex;flex-direction:column;gap:0.4rem;">
      <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-muted);">Preview</span>
      <div id="preview" style="flex:1;background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.2rem 1.4rem;overflow:auto;min-height:500px;"></div>
    </div>
  </div>

  <style>
    #preview h1,#preview h2,#preview h3,#preview h4,#preview h5,#preview h6 { color:var(--color-heading); font-weight:700; margin:1.1em 0 0.4em; line-height:1.25; }
    #preview h1 { font-size:1.7rem; border-bottom:1px solid var(--color-border); padding-bottom:0.3em; }
    #preview h2 { font-size:1.35rem; border-bottom:1px solid var(--color-border); padding-bottom:0.2em; }
    #preview h3 { font-size:1.1rem; }
    #preview h4 { font-size:0.95rem; }
    #preview h5,#preview h6 { font-size:0.85rem; }
    #preview p  { color:var(--color-body); margin:0.6em 0; line-height:1.7; }
    #preview a  { color:var(--color-accent); text-decoration:underline; }
    #preview strong { color:var(--color-heading); font-weight:700; }
    #preview em { font-style:italic; }
    #preview code { font-family:'JetBrains Mono',monospace; font-size:0.82em; background:var(--color-surface2); color:#a8ffb0; padding:0.15em 0.4em; border-radius:4px; }
    #preview pre { background:var(--color-surface2); border:1px solid var(--color-border); border-radius:10px; padding:1rem; overflow:auto; margin:0.8em 0; }
    #preview pre code { background:none; padding:0; color:#a8ffb0; font-size:0.83rem; }
    #preview blockquote { border-left:3px solid var(--color-accent); margin:0.8em 0; padding:0.4em 1rem; background:rgba(99,102,241,0.06); color:var(--color-muted); border-radius:0 8px 8px 0; }
    #preview blockquote p { margin:0; }
    #preview ul,#preview ol { color:var(--color-body); padding-left:1.4em; margin:0.5em 0; }
    #preview li { margin:0.25em 0; line-height:1.6; }
    #preview hr { border:none; border-top:1px solid var(--color-border); margin:1.2em 0; }
    #preview img { max-width:100%; border-radius:8px; }
    #preview table { width:100%; border-collapse:collapse; margin:0.8em 0; font-size:0.87rem; }
    #preview th { background:var(--color-surface2); color:var(--color-heading); font-weight:600; padding:0.4em 0.75em; border:1px solid var(--color-border); text-align:left; }
    #preview td { color:var(--color-body); padding:0.4em 0.75em; border:1px solid var(--color-border); }
  </style>

</Base>

<script>
  const DEFAULT_MD = `# Hello, Markdown!

This is a **live preview** editor. Edit the left pane to see changes here.

## Features

- **Bold** and *italic* text
- \`inline code\` snippets
- [Links](https://example.com) and images
- Blockquotes, lists, and code blocks

### Code Block

\`\`\`js
function greet(name) {
  return \`Hello, \${name}!\`;
}
\`\`\`

> Blockquotes look like this.
> They can span multiple lines.

---

1. Ordered list item one
2. Ordered list item two
3. Ordered list item three

![Sample image](https://placehold.co/600x200/141720/6366F1?text=Image+Placeholder)
`;

  function parseMarkdown(md: string): string {
    let html = md
      // Escape HTML entities first (except inside code blocks — handled separately)
      // Code fences
      .replace(/```(\w*)\n([\s\S]*?)```/g, (_m, lang, code) => {
        const escaped = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        return `<pre><code class="language-${lang}">${escaped}</code></pre>`;
      })
      // Headings
      .replace(/^###### (.+)$/gm, '<h6>$1</h6>')
      .replace(/^##### (.+)$/gm,  '<h5>$1</h5>')
      .replace(/^#### (.+)$/gm,   '<h4>$1</h4>')
      .replace(/^### (.+)$/gm,    '<h3>$1</h3>')
      .replace(/^## (.+)$/gm,     '<h2>$1</h2>')
      .replace(/^# (.+)$/gm,      '<h1>$1</h1>')
      // HR
      .replace(/^---$/gm, '<hr>')
      // Blockquotes
      .replace(/^> (.+)$/gm, '<blockquote><p>$1</p></blockquote>')
      // Unordered lists
      .replace(/^([ \t]*[-*+] .+(\n|$))+/gm, (block) => {
        const items = block.trim().split('\n').map(l => `<li>${l.replace(/^[ \t]*[-*+] /, '')}</li>`).join('');
        return `<ul>${items}</ul>`;
      })
      // Ordered lists
      .replace(/^([ \t]*\d+\. .+(\n|$))+/gm, (block) => {
        const items = block.trim().split('\n').map(l => `<li>${l.replace(/^[ \t]*\d+\. /, '')}</li>`).join('');
        return `<ol>${items}</ol>`;
      })
      // Images before links
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">')
      // Links
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
      // Bold + italic
      .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
      // Bold
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      // Italic
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      // Inline code
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      // Paragraphs: wrap lines not already wrapped in block elements
      .replace(/^(?!<[h1-6|ul|ol|li|pre|blockquote|hr|img])(.+)$/gm, (line) => {
        if (line.trim() === '') return '';
        if (/^<(h[1-6]|ul|ol|li|pre|blockquote|hr|img|\/ul|\/ol|\/li|\/pre|\/blockquote)/.test(line)) return line;
        return `<p>${line}</p>`;
      });

    return html;
  }

  function renderMd() {
    const raw = (document.getElementById('md-input') as HTMLTextAreaElement).value;
    document.getElementById('preview')!.innerHTML = parseMarkdown(raw);
  }

  function copyHTML() {
    const html = document.getElementById('preview')!.innerHTML;
    navigator.clipboard.writeText(html).then(() => {
      const s = document.getElementById('status')!;
      s.textContent = '✓ Copied!'; s.style.color = 'var(--color-success)';
      setTimeout(() => { s.textContent = ''; }, 2000);
    });
  }

  // Initialize with default content
  const ta = document.getElementById('md-input') as HTMLTextAreaElement;
  ta.value = DEFAULT_MD;
  renderMd();

  (window as any).renderMd  = renderMd;
  (window as any).copyHTML  = copyHTML;
</script>
