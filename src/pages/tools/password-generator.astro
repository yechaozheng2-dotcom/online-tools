---
import Base from '../../layouts/Base.astro';
---
<Base title="Password Generator" description="Free secure password generator. Generate strong random passwords with custom length and character rules. Uses Web Crypto API — runs entirely in your browser.">

  <nav style="font-size:0.8rem;color:var(--color-muted);margin-bottom:1.5rem;">
    <a href="/" style="color:var(--color-muted);text-decoration:none;" onmouseover="this.style.color='var(--color-heading)'" onmouseout="this.style.color='var(--color-muted)'">All Tools</a>
    <span style="margin:0 0.5rem;">›</span>
    <span style="color:var(--color-body);">Password Generator</span>
  </nav>

  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
      <span style="font-size:1.5rem;">🔑</span>
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--color-heading);margin:0;">Password Generator</h1>
    </div>
    <p style="color:var(--color-muted);font-size:0.9rem;margin:0;">Generate cryptographically secure passwords using your browser's Web Crypto API. Nothing is stored or transmitted.</p>
  </div>

  <div style="max-width:560px;">
    <!-- Output -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:14px;padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
        <span id="pw-output" style="font-family:'JetBrains Mono',monospace;font-size:1.1rem;font-weight:500;color:var(--color-heading);letter-spacing:0.05em;word-break:break-all;flex:1;"></span>
        <button onclick="copyPw()" style="flex-shrink:0;padding:0.4rem 0.75rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:8px;font-size:0.8rem;cursor:pointer;" title="Copy">📋</button>
      </div>
      <!-- Strength bar -->
      <div style="margin-top:0.75rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
          <span style="font-size:0.75rem;color:var(--color-muted);">Strength</span>
          <span id="strength-label" style="font-size:0.75rem;font-weight:600;"></span>
        </div>
        <div style="height:5px;border-radius:999px;background:var(--color-border);overflow:hidden;">
          <div id="strength-bar" style="height:100%;width:0%;border-radius:999px;transition:width 0.3s,background 0.3s;"></div>
        </div>
      </div>
    </div>

    <!-- Options -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:14px;padding:1.5rem;margin-bottom:1rem;">
      <!-- Length -->
      <div style="margin-bottom:1.25rem;">
        <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;">
          <label style="font-size:0.85rem;font-weight:500;color:var(--color-body);">Length</label>
          <span id="len-val" style="font-family:'JetBrains Mono',monospace;font-size:0.9rem;color:var(--color-accent);font-weight:600;">16</span>
        </div>
        <input id="length" type="range" min="8" max="64" value="16" oninput="document.getElementById('len-val').textContent=this.value;generate()"
          style="width:100%;accent-color:var(--color-accent);" />
        <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--color-muted);margin-top:0.2rem;"><span>8</span><span>64</span></div>
      </div>

      <!-- Checkboxes -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
        {[
          ['cb-upper','Uppercase (A–Z)','checked'],
          ['cb-lower','Lowercase (a–z)','checked'],
          ['cb-digits','Numbers (0–9)','checked'],
          ['cb-symbols','Symbols (!@#$…)',''],
          ['cb-similar','Exclude similar (0Ol1I)',''],
        ].map(([id,label,checked]) => (
          <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;color:var(--color-body);cursor:pointer;">
            <input type="checkbox" id={id} checked={checked === 'checked' || undefined} onchange="generate()" style="accent-color:var(--color-accent);width:15px;height:15px;" />
            {label}
          </label>
        ))}
      </div>
    </div>

    <!-- Buttons -->
    <div style="display:flex;gap:0.5rem;">
      <button onclick="generate()" style="flex:1;padding:0.6rem 1rem;background:var(--color-accent);color:#fff;border:none;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
        🔄 Generate New
      </button>
      <button onclick="copyPw()" style="padding:0.6rem 1.25rem;background:var(--color-surface2);color:var(--color-body);border:1px solid var(--color-border);border-radius:10px;font-size:0.9rem;font-weight:500;cursor:pointer;">
        📋 Copy
      </button>
    </div>
    <div id="copy-status" style="font-size:0.8rem;color:var(--color-success);min-height:1rem;margin-top:0.5rem;font-family:'JetBrains Mono',monospace;"></div>
  </div>
</Base>

<script>
  function getCharset(): string {
    const upper   = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const lower   = 'abcdefghijklmnopqrstuvwxyz';
    const digits  = '0123456789';
    const symbols = '!@#$%^&*()-_=+[]{}|;:,.<>?';
    const similar = new Set('0Ol1Ii');

    let chars = '';
    if ((document.getElementById('cb-upper') as HTMLInputElement)?.checked)   chars += upper;
    if ((document.getElementById('cb-lower') as HTMLInputElement)?.checked)   chars += lower;
    if ((document.getElementById('cb-digits') as HTMLInputElement)?.checked)  chars += digits;
    if ((document.getElementById('cb-symbols') as HTMLInputElement)?.checked) chars += symbols;

    if ((document.getElementById('cb-similar') as HTMLInputElement)?.checked)
      chars = [...chars].filter(c => !similar.has(c)).join('');

    return chars || upper + lower + digits;
  }

  function generate() {
    const len = parseInt((document.getElementById('length') as HTMLInputElement).value);
    const charset = getCharset();
    const arr = new Uint32Array(len);
    crypto.getRandomValues(arr);
    const pw = Array.from(arr).map(n => charset[n % charset.length]).join('');
    document.getElementById('pw-output')!.textContent = pw;
    updateStrength(pw);
    document.getElementById('copy-status')!.textContent = '';
  }

  function updateStrength(pw: string) {
    let score = 0;
    if (pw.length >= 12) score++;
    if (pw.length >= 16) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[a-z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;

    const bar = document.getElementById('strength-bar')!;
    const label = document.getElementById('strength-label')!;
    const levels = [
      { pct:'20%', color:'#EF4444', text:'Weak' },
      { pct:'40%', color:'#F97316', text:'Fair' },
      { pct:'60%', color:'#EAB308', text:'Good' },
      { pct:'80%', color:'#22C55E', text:'Strong' },
      { pct:'100%', color:'#06B6D4', text:'Very Strong' },
      { pct:'100%', color:'#6366F1', text:'Excellent' },
    ];
    const lvl = levels[Math.min(score, 5)];
    bar.style.width = lvl.pct;
    bar.style.background = lvl.color;
    label.textContent = lvl.text;
    label.style.color = lvl.color;
  }

  function copyPw() {
    const pw = document.getElementById('pw-output')!.textContent;
    if (!pw) return;
    navigator.clipboard.writeText(pw).then(() => {
      document.getElementById('copy-status')!.textContent = '✓ Copied to clipboard!';
    });
  }

  (window as any).generate = generate;
  (window as any).copyPw = copyPw;

  generate();
</script>
