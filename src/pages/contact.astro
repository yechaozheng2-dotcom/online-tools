---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact — Tool.top1pick.com"
  description="Get in touch with the Tool.top1pick.com team for questions, tool suggestions, or bug reports."
>
  <div style="max-width: 640px; margin: 0 auto; padding: 3rem 0;">
    <h1 style="font-size: 2rem; font-weight: 700; color: var(--color-heading); margin-bottom: 0.75rem;">Contact Us</h1>
    <p style="color: var(--color-muted); margin-bottom: 2.5rem;">Have a question, tool suggestion, or bug report? We'd love to hear from you.</p>

    <div style="display: flex; flex-direction: column; gap: 2rem;">
      <div>
        <h2 style="font-size: 1.125rem; font-weight: 600; color: var(--color-heading); margin-bottom: 0.5rem;">Get in Touch</h2>
        <p style="color: var(--color-body);">
          You can reach us by email at:
          <br />
          <a href="mailto:hello@tool.top1pick.com" style="color: var(--color-accent); font-weight: 600;">hello@tool.top1pick.com</a>
        </p>
      </div>

      <div>
        <h2 style="font-size: 1.125rem; font-weight: 600; color: var(--color-heading); margin-bottom: 0.75rem;">What We Can Help With</h2>
        <ul style="color: var(--color-body); display: flex; flex-direction: column; gap: 0.5rem; padding-left: 1.25rem;">
          <li><strong>Tool suggestions</strong> — A utility you'd like us to build</li>
          <li><strong>Bug reports</strong> — Something not working as expected</li>
          <li><strong>General questions</strong> — Anything about the site or a specific tool</li>
          <li><strong>Partnership inquiries</strong> — Sponsorship or collaboration</li>
        </ul>
      </div>

      <div>
        <h2 style="font-size: 1.125rem; font-weight: 600; color: var(--color-heading); margin-bottom: 0.5rem;">Response Time</h2>
        <p style="color: var(--color-body);">We aim to respond to all emails within 2–3 business days.</p>
      </div>

      <p style="font-size: 0.8rem; color: var(--color-muted);">
        Tool.top1pick.com is operated at <a href="https://tool.top1pick.com" style="color: var(--color-accent);">tool.top1pick.com</a>. All tools run entirely in your browser — we don't collect or store your data.
      </p>
    </div>
  </div>
</Base>
