---
import Base from '../layouts/Base.astro';
import { tools, categories } from '../data/tools';
---
<Base title="Free Online Tools">
  <div class="text-center mb-10">
    <h1 class="text-4xl font-bold text-gray-900 mb-3">Free Online Tools</h1>
    <p class="text-lg text-gray-500">Fast, free, private — everything runs in your browser.</p>
  </div>

  {categories.map(cat => (
    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-4">{cat}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {tools.filter(t => t.category === cat).map(tool => (
          <a href={`/tools/${tool.slug}`}
             class="bg-white border border-gray-200 rounded-xl p-5 hover:border-indigo-400 hover:shadow-md transition group">
            <div class="text-2xl font-mono text-indigo-500 mb-3 group-hover:scale-110 transition-transform inline-block">
              {tool.icon}
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">{tool.name}</h3>
            <p class="text-sm text-gray-500">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>
